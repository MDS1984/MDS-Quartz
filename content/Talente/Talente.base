views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder == "Talente"
        - file.path != "Talente/Talente.base"
    order:
      - Klasse
      - file.name
      - Pfadtalent
      - Englisch
    sort:
      - property: Klasse
        direction: ASC
      - property: Pfadtalent
        direction: ASC
    columnSize:
      note.Pfadtalent: 319
