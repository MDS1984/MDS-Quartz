views:
  - type: table
    name: Table
    filters:
      and:
        - "!Gruppenname.isEmpty()"
    order:
      - Gruppenname
      - image
  - type: cards
    name: Karten
    filters:
      and:
        - "!Gruppenname.isEmpty()"
    order:
      - Gruppenname
    image: note.image
    imageFit: contain
    cardSize: 200
    imageAspectRatio: 1
